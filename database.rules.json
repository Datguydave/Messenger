{
  "rules": {
    // ── Users ──────────────────────────────────────────────────────
    "users": {
      "$uid": {
        ".read":  "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // ── Username index (read for uniqueness checks, write own) ──────
    "usernames": {
      ".read": true,
      "$username": {
        ".write": "auth != null"
      }
    },

    // ── Online presence ────────────────────────────────────────────
    "onlineUsers": {
      ".read":  "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // ── Friend requests ────────────────────────────────────────────
    "friendRequests": {
      "$targetUid": {
        ".read":  "auth != null && auth.uid === $targetUid",
        "$senderUid": {
          ".write": "auth != null && (auth.uid === $senderUid || auth.uid === $targetUid)"
        }
      }
    },

    // ── Friends ────────────────────────────────────────────────────
    "friends": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        "$friendUid": {
          ".write": "auth != null && (auth.uid === $uid || auth.uid === $friendUid)"
        }
      }
    },

    // ── Direct messages ────────────────────────────────────────────
    "dms": {
      "$chatId": {
        ".read":  "auth != null && ($chatId.contains(auth.uid))",
        "$messageId": {
          ".write": "auth != null && ($chatId.contains(auth.uid))"
        }
      }
    },

    // ── Servers ────────────────────────────────────────────────────
    "servers": {
      ".read": "auth != null",
      "$serverId": {
        ".write": "auth != null"
      }
    },

    // ── Server members ──────────────────────────────────────────────
    "serverMembers": {
      "$serverId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null"
        }
      }
    },

    // ── User → server mapping ───────────────────────────────────────
    "userServers": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // ── Channels ────────────────────────────────────────────────────
    "channels": {
      "$serverId": {
        ".read": "auth != null",
        "$channelId": {
          ".write": "auth != null && root.child('serverMembers').child($serverId).child(auth.uid).exists()"
        }
      }
    },

    // ── Server messages ─────────────────────────────────────────────
    "messages": {
      "$serverId": {
        "$channelId": {
          ".read":  "auth != null && root.child('serverMembers').child($serverId).child(auth.uid).exists()",
          "$messageId": {
            ".write": "auth != null && root.child('serverMembers').child($serverId).child(auth.uid).exists()"
          }
        }
      }
    },

    // ── Typing indicators ───────────────────────────────────────────
    "typing": {
      "$serverId": {
        "$channelId": {
          ".read":  "auth != null && root.child('serverMembers').child($serverId).child(auth.uid).exists()",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },

    // ── Reactions ───────────────────────────────────────────────────
    "reactions": {
      "$reactionKey": {
        ".read":  "auth != null",
        "$emoji": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },

    // ── Notifications ───────────────────────────────────────────────
    "notifications": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null"
      }
    }
  }
}
